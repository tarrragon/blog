#!/usr/bin/env bash
# Blog pre-commit hook — runs mdtools against staged markdown files
# + reminds about #69 RED-GREEN protocol when test files are touched.
#
# Pipeline:
#   0. Test-First reminder if .spec.ts is staged (#69 / #72 L3 trigger).
#   1. fmt --fix on each staged .md; re-stage if changed.
#   2. lint on all staged .md; abort commit on error.
#   3. cards on content/ globally; abort on error.
#
# Bypass with `git commit --no-verify` only when truly necessary.
# See content/posts/markdown-writing-spec.md for the rule contract.

set -euo pipefail

MDTOOLS_BIN="bin/mdtools"
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# --- 0. Test-First (#69) reminder when test files are staged ---------------
# This is a #72 L3 structural trigger: the act of committing a test triggers
# a question. Goal: "did you see RED on buggy code, or are you committing
# a placebo test that always passes?"
#
# Non-blocking — prints a reminder + asks for confirmation. Skip with
# COMMIT_SKIP_TEST_FIRST=1 (e.g. for refactors that don't change test semantics).
staged_tests=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.spec\.(ts|js)$|tests/.*\.(ts|js)$' || true)
if [[ -n "$staged_tests" && "${COMMIT_SKIP_TEST_FIRST:-0}" != "1" && -t 0 ]]; then
    echo ""
    echo "  [pre-commit] Test files staged:"
    echo "$staged_tests" | sed 's/^/    /'
    echo ""
    echo "  #69 RED-GREEN check:"
    echo "  - Did you see this test FAIL on buggy / pre-fix code?"
    echo "  - If GREEN-only, the test might be a placebo (5 failure modes — see #69)."
    echo "  - Use 'make verify-red-green PRE_FIX=<commit-sha>' to retroactively verify."
    echo "  - Skip this check: COMMIT_SKIP_TEST_FIRST=1 git commit ..."
    echo ""
    read -r -p "  Continue commit? [y/N] " response < /dev/tty
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
        echo "[pre-commit] commit aborted by Test-First reminder" >&2
        exit 1
    fi
fi

# Fast exit if no staged .md files.
staged_md=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.md$' || true)
if [[ -z "$staged_md" ]]; then
    exit 0
fi

# Rebuild mdtools if sources newer than binary (or binary missing).
if [[ ! -x "$MDTOOLS_BIN" ]] || [[ -n "$(find scripts/mdtools -type f -name '*.go' -newer "$MDTOOLS_BIN" 2>/dev/null || true)" ]]; then
    echo "[pre-commit] rebuilding mdtools..."
    if ! (cd scripts/mdtools && go build -o "$REPO_ROOT/$MDTOOLS_BIN" .); then
        echo "[pre-commit] mdtools build failed; aborting commit" >&2
        exit 1
    fi
fi

# --- 1. fmt --fix + re-stage -----------------------------------------------
echo "[pre-commit] mdtools fmt --fix on staged markdown"
restaged=0
while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    before=$(git hash-object "$f" 2>/dev/null || echo "")
    "$MDTOOLS_BIN" fmt --fix "$f" >/dev/null
    after=$(git hash-object "$f" 2>/dev/null || echo "")
    if [[ "$before" != "$after" ]]; then
        git add "$f"
        restaged=$((restaged + 1))
    fi
done <<< "$staged_md"
if [[ "$restaged" -gt 0 ]]; then
    echo "[pre-commit] re-staged $restaged file(s) after fmt --fix"
fi

# --- 2. lint on staged set -------------------------------------------------
# mdtools lint targets Hugo content (frontmatter, H1 conventions, etc).
# Restrict to content/** — repo-root docs (README, AGENTS) and skill files
# (.claude/skills/) follow different conventions and should be exempt.
echo "[pre-commit] mdtools lint on staged markdown (content/ only)"
lint_args=()
while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    [[ "$f" != content/* ]] && continue
    lint_args+=("$f")
done <<< "$staged_md"
if [[ ${#lint_args[@]} -gt 0 ]]; then
    if ! "$MDTOOLS_BIN" lint "${lint_args[@]}"; then
        echo "[pre-commit] lint errors present; fix and re-stage" >&2
        exit 1
    fi
fi

# --- 3.5 Skill mirror sync check (#96) ------------------------------------
# AGENTS.md §9: .claude/skills/<x>/ 跟 content/skills/<x>/ 是 mirror、主體相同。
# 改一邊沒改另一邊是 #95/#96 反覆踩到的 case — 同 surface 的同類風險區。
# 這一步檢查：staged 動到一邊、另一邊沒 staged 就警告（非阻擋、避免 link 格式
# 差異的 false positive；只抓「忘了同步」這個失誤模式）。
# Skip with COMMIT_SKIP_MIRROR_CHECK=1.
if [[ "${COMMIT_SKIP_MIRROR_CHECK:-0}" != "1" ]]; then
    mirror_warnings=""
    staged_set=$(git diff --cached --name-only --diff-filter=ACMR)
    # .claude/ → content/ direction
    while IFS= read -r claude_path; do
        [[ -z "$claude_path" ]] && continue
        skill=$(echo "$claude_path" | cut -d'/' -f3)
        rest=${claude_path#.claude/skills/$skill/}
        case "$rest" in
            SKILL.md) mirror_path="content/skills/$skill/skill.md" ;;
            references/principles/*) continue ;;
            references/*) mirror_path="content/skills/$skill/${rest#references/}" ;;
            *) continue ;;
        esac
        [[ ! -f "$mirror_path" ]] && continue
        if ! echo "$staged_set" | grep -qFx "$mirror_path"; then
            mirror_warnings+="    $claude_path → $mirror_path"$'\n'
        fi
    done <<< "$(echo "$staged_set" | grep -E '^\.claude/skills/[^/]+/(SKILL\.md|references/.+\.md)$' || true)"
    # content/ → .claude/ direction
    while IFS= read -r content_path; do
        [[ -z "$content_path" ]] && continue
        skill=$(echo "$content_path" | cut -d'/' -f3)
        rest=${content_path#content/skills/$skill/}
        [[ "$rest" == "_index.md" ]] && continue
        case "$rest" in
            skill.md) mirror_path=".claude/skills/$skill/SKILL.md" ;;
            *) mirror_path=".claude/skills/$skill/references/$rest" ;;
        esac
        [[ ! -f "$mirror_path" ]] && continue
        if ! echo "$staged_set" | grep -qFx "$mirror_path"; then
            mirror_warnings+="    $content_path → $mirror_path"$'\n'
        fi
    done <<< "$(echo "$staged_set" | grep -E '^content/skills/[^/]+/[^/]+\.md$' || true)"
    if [[ -n "$mirror_warnings" ]]; then
        echo ""
        echo "  [pre-commit] ⚠ Mirror staged unilaterally (#96 enumeration miss):"
        printf '%s' "$mirror_warnings"
        echo ""
        echo "  Skill mirror requires both surfaces to update together (AGENTS.md §9)."
        echo "  Either stage the mirror too, or skip with COMMIT_SKIP_MIRROR_CHECK=1."
        if [[ -t 0 ]]; then
            read -r -p "  Continue commit anyway? [y/N] " response < /dev/tty
            if [[ ! "$response" =~ ^[Yy]$ ]]; then
                echo "[pre-commit] commit aborted by mirror check" >&2
                exit 1
            fi
        else
            echo "  (non-interactive: continuing — set COMMIT_SKIP_MIRROR_CHECK=1 to suppress)"
        fi
    fi
fi

# --- 3. cards on full content/ --------------------------------------------
# Cross-file checks (orphan, backlinks) require the whole graph, so we
# scan content/ rather than only the staged subset.
echo "[pre-commit] mdtools cards on content/"
if ! "$MDTOOLS_BIN" cards content/; then
    echo "[pre-commit] cards check failed" >&2
    exit 1
fi

exit 0
