# Hugo build output
public/

# Hugo cache
.hugo_build.lock
resources/

# mdtools build output (Go binary; see scripts/mdtools/README.md)
bin/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Temporary files
*.tmp
*.swp

# Local convenience symlink for serving /blog/ subpath on localhost
/blog

# Claude Code runtime lock (ScheduleWakeup / scheduled tasks)
.claude/scheduled_tasks.lock

# Playwright MCP runtime cache (snapshots, console logs)
.playwright-mcp/

# Playwright test artifacts
node_modules/
.test-www/
test-results/
playwright-report/
playwright/.cache/

# RAG / MCP demo build artifacts (regenerable)
scripts/rag-demo/index.pkl
scripts/rag-demo/__pycache__/
scripts/mcp-demo/__pycache__/

# blogsearch index (regenerable via `blogsearch ingest`)
.blogsearch/

# 編輯器 markdown 預覽暫存檔（Notepad++ 等）
.npp-md-preview.html
*-md-preview.html
